{
  "model": "deepseek-v4-pro",
  "fallbackModel": "deepseek-v4-flash",
  "providers": {
    "deepseek": {
      "baseUrl": "https://api.deepseek.com/v1",
      "apiKey": "${OMP_DEEPSEEK_KEY}"
    }
  },
  "apiKeys": {
    "anthropic": "${OMP_ANTHROPIC_KEY}",
    "deepseek": "${OMP_DEEPSEEK_KEY}"
  },
  "yolo": false,
  "theme": "dark",
  "compaction": {
    "auto": true,
    "threshold": 0.75
  },
  "extensions": [
    "@oh-my-pi/swarm-extension",
    "@the-agency/pi-hashline-edit"
  ],
  "task": {
    "maxConcurrent": 5,
    "model": "deepseek-v4-flash"
  }
}
